OPENROUTER_API_KEY=your_openrouter_api_key_here
# Single source of truth for OpenRouter model selection:
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Access control for web/API endpoints (HTTP Basic Auth)
ACCESS_PASSWORD=Recon103!
ACCESS_AUTH_ENABLED=1
# Optional: stream timeout/retry controls for model calls
LLM_STREAM_TIMEOUT_SEC=90
LLM_STREAM_MAX_RETRIES=1
# Optional: include provider/model/key-format diagnostics in worker error messages
LLM_DEBUG_ERRORS=1
# Optional: truth verification strictness policy for deep scans
# Values: strict | balanced | aggressive
TRUTH_VERIFICATION_POLICY=balanced
# Optional: passive recon primary backend (Netlas-first)
NETLAS_API_KEY=
# Optional: passive recon secondary backend (used only when Netlas auth/quota limits are hit)
SHODAN_API_KEY=
# Optional: WPScan vulnerability API token
WPSCAN_API_TOKEN=
